[Unit]
Description=Nightly Agent — 야간 코드 리뷰 파이프라인
After=network-online.target ollama.service
Wants=ollama.service

[Service]
Type=oneshot
User=seoy
WorkingDirectory=/opt/python/src/github.com/HeaInSeo/nightly-agent
ExecStart=/opt/python/src/github.com/HeaInSeo/nightly-agent/venv/bin/python3 nightly_run_all.py
StandardOutput=journal
StandardError=journal
SyslogIdentifier=nightly-agent

[Install]
WantedBy=multi-user.target
