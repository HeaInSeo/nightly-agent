{
  "llm": {
    "api_base_url": "http://localhost:11434/v1",
    "model_name": "qwen3.6:27b",
    "api_key": "",
    "timeout_seconds": 900,
    "temperature": 0,
    "reasoning_effort": "none",
    "disable_thinking": true,
    "review_max_tokens": 480,
    "continuity_max_tokens": 600,
    "fix_max_tokens": 1200
  },
  "max_diff_lines": 2000,
  "max_retries": 3,
  "review": {
    "level": 1,
    "max_level": 3,
    "auto_promote": true
  },
  "phase2": {
    "min_severity": "high",
    "min_severity_by_level": {
      "1": "high",
      "2": "high",
      "3": "medium"
    }
  },
  "full_review_on_clean": true,
  "large_diff_review": {
    "enabled": true,
    "max_files": 10,
    "max_lines_per_file": 300,
    "cross_file_pass": true
  },
  "phase1_timeout_sec": 5400,
  "phase2_timeout_sec": 1800,
  "language": "ko",

  "github": {
    "enabled": false,
    "token": "",
    "reports_repo": "HeaInSeo/nightly-agent-reports"
  },

  "scan_paths": [
    "/opt/go/src/github.com/HeaInSeo",
    "/opt/dotnet/src/github.com/HeaInSeo",
    "/opt/python/src/github.com/HeaInSeo"
  ],

  "clone_roots": {
    "go":         "/opt/go/src/github.com",
    "rust":       "/opt/rust/src/github.com",
    "dotnet":     "/opt/dotnet/src/github.com",
    "typescript": "/opt/node/src/github.com",
    "python":     "/opt/python/src/github.com",
    "shell":      "/opt/shell/src/github.com",
    "infra":      "/opt/infra/src/github.com"
  },

  "cron_hour": "2am",
  "cron_min": 0,
  "deadline_hour": "8am",
  "deadline_minute": 0
}
